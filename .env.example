# GEMINI_API_KEY: Required for Gemini AI features (voice/image/text processing).
GEMINI_API_KEY=""

# FIREBASE_PROJECT_ID: Fallback if firebase-applet-config.json is missing.
FIREBASE_PROJECT_ID=""

# NODE_ENV: Set to 'production' for deployment.
NODE_ENV="development"

# PostgreSQL Configuration
# IMPORTANT: 'localhost' will NOT work in the AI Studio preview.
# For VPS deployment, use 'localhost' or the server IP.
DB_HOST="your-postgres-host"
DB_USER="postgres"
DB_PASSWORD=""
DB_NAME="cloud_erp_system"
DB_PORT="5432"
